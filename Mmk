# ================= WORKER =================
async def worker(chat_id, msg, queue, mode, progress_msg, total_users):
    while running_tagall.get(chat_id):

        batch = []

        for _ in range(BATCH_SIZE):
            try:
                user = queue.get_nowait()
                batch.append(user)
            except asyncio.QueueEmpty:
                break

        if not batch:
            break

        base_text = f"{msg}\n\n🛍 my store @storegarf"
        messages = split_message(base_text, batch)

        for text in messages:
            if not running_tagall.get(chat_id):
                break

            sent_msg = await safe_send(
                chat_id,
                text,
                reply_to=msg if mode == "balas" else None,
                buttons=[[Button.inline("STOP", b"stop_tagall")]]
            )

            if sent_msg:
                spam_chats.setdefault(f"messages_{chat_id}", []).append(sent_msg.id)
                message_ids.setdefault(chat_id, []).append(sent_msg.id)

        async with progress_lock:
            progress_count[chat_id] += len(batch)
            current = progress_count[chat_id]

        if progress_msg and random.random() > 0.85:  # ❗ kurangi edit biar ga lag
            try:
                await progress_msg.edit(f"⚡ Tagging...\n✔ {current}/{total_users}")
            except:
                pass

        await asyncio.sleep(random.uniform(DELAY_MIN, DELAY_MAX))
        await asyncio.sleep(0)  # ❗ anti freeze


