# CONFIG (DI GAS DIKIT)
BATCH_SIZE = 3
DELAY_MIN = 0.5
DELAY_MAX = 1.0
WORKERS = 4
MAX_MSG_LEN = 3500

WAJIB_JOIN_CHANNEL = "storegarf"

running_tagall = {}
progress_count = {}
progress_lock = asyncio.Lock()


# ================= SAFE SEND =================
async def safe_send(chat_id, text, reply_to=None, buttons=None):
    while True:
        try:
            if reply_to:
                return await reply_to.reply(text, buttons=buttons)
            else:
                return await kntl.send_message(chat_id, text, buttons=buttons)

        except FloodWaitError as e:
            wait = min(e.seconds, 15)  # ❗ cegah diem lama
            print(f"[FLOOD] {e.seconds}s → {wait}s")
            await asyncio.sleep(wait)

        except Exception as e:
            print("ERROR SEND:", e)
            await asyncio.sleep(1)
            return None


# ================= SPLIT MESSAGE =================
def split_message(base_text, mentions):
    chunks = []
    current = base_text

    for m in mentions:
        if len(current) + len(m) + 1 > MAX_MSG_LEN:
            chunks.append(current)
            current = base_text + "\n\n" + m
        else:
            current += " " + m

    chunks.append(current)
    return chunks


