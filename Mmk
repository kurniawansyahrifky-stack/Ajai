@kntl.on(events.NewMessage(pattern="^/broadcast (.+)"))
async def broadcast(event):
    user_id = event.sender_id
    if user_id not in OWNER_IDS:
        return await event.reply("Lu siapa anjg? Ini cuma buat owner.")

    text = event.pattern_match.group(1)

    for uid in started_users:
        try:
            await kntl.send_message(uid, text)
        except:
            continue

    for gid in admin_groups:
        try:
            await kntl.send_message(gid, text)
        except:
            continue

    await event.reply("✅ Broadcast selesai!")

