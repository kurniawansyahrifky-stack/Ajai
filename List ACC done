# ================= PARTNER SYSTEM =================
def normalize_link(link):
    link = link.strip()
    link = link.replace("https://", "").replace("http://", "")
    link = link.replace("t.me/", "")
    return link.lower()
def load_partner():
    try:
        with open(PARTNER_FILE, "r") as f:
            return json.load(f)
    except:
        return []
def save_partner(data):
    with open(PARTNER_FILE, "w") as f:
        json.dump(data, f, indent=2)
def get_group_name(link):
    try:
        username = normalize_link(link)
        entity = loop.run_until_complete(client.get_entity(username))
        return entity.title
    except Exception as e:
        print("❌  gagal ambil nama:", e)
        return "Unknown"
def add_partner(update, context):
    if update.effective_user.id != OWNER_ID:
        return
    try:
        link = context.args[0]
    except:
        update.message.reply_text("❌  format: /addpartner link")
        return
    username = normalize_link(link)
    data = load_partner()
    for p in data:
        if "username" in p and p["username"] == username:
            update.message.reply_text("⚠️ sudah ada")
            return
    name = get_group_name(link)
    data.append({
        "link": f"https://t.me/{username}",
        "username": username,
        "name": name
    })
    save_partner(data)
    update.message.reply_text(f"✅  partner ditambah\n{name}")
def del_partner(update, context):
    if update.effective_user.id != OWNER_ID:
        return
    try:
        link = context.args[0]
    except:
        update.message.reply_text("❌  format: /delpartner link")
        return
    username = normalize_link(link)
    data = load_partner()
    new_data = []
    for p in data:
        if "username" in p:
            if p["username"] != username:
                new_data.append(p)
    if len(new_data) == len(data):
        update.message.reply_text("❌  tidak ditemukan")
        return
    save_partner(new_data)
    update.message.reply_text("✅  partner dihapus")
def list_partner(update, context):
    if update.effective_user.id != OWNER_ID:
        return
    data = load_partner()
    if not data:
        update.message.reply_text("❌  kosong")
        return
    text = "📋 LIST PARTNER:\n\n"
    for i, p in enumerate(data, 1):
        text += f"{i}. {p['link']}\n   {p['name']}\n\n"
    update.message.reply_text(text)
# ================= TELETHON =================
async def scrape(chat_id):
    users = {}
    try:
        dialogs = await client.get_dialogs()
        entity = None
        for d in dialogs:
            if d.id == chat_id:
                entity = d.entity
                break
        if not entity:
            print("❌  entity ga ketemu")
            return {}
        async for u in client.iter_participants(entity):
            if not u.bot and u.first_name:
                users[str(u.id)] = u.first_name
    except Exception as e:
        print("❌  scrape error:", e)
    return users

# ================= MEMBER =================
def get_members(chat_id):
    merged = {}
    try:
        r = requests.get(f"{API_URL}?chat_id={chat_id}", timeout=5)
        api_data = r.json()
    except:
        api_data = {}
    try:
        live_data = loop.run_until_complete(scrape(chat_id))
    except:
        live_data = {}
    for uid, name in api_data.items():
        merged[str(uid)] = name
    for uid, name in live_data.items():
        merged[str(uid)] = name
    return merged
# ================= TAGALL =================
def tagall_worker():
    print("🔥 WORKER HIDUP")
    while True:
        chat_id, text = task_queue.get()
        members = get_members(chat_id)
        if not members:
            task_queue.task_done()
            continue
        user_ids = list(members.keys())
        user_ids = user_ids[5:] + user_ids[:5]
        total = len(user_ids)
        sent = 0
        start_time = time.time()
        duration = 300
        while time.time() - start_time < duration:
            for i in range(0, total, BATCH_SIZE):
                if time.time() - start_time >= duration:
                    break
                batch = user_ids[i:i+BATCH_SIZE]
                mention_text = ""
                for uid in batch:
                    name = members[uid]
                    mention_text += f"[{name}](tg://user?id={uid}) "
                try:
                    bot.send_message(
                        chat_id,
                        f"🔥 TAGALL START\n\n{text}\n\n{mention_text}",
                        parse_mode="Markdown"
                    )
                except Exception as e:
                    print("❌ ", e)
                sent += len(batch)
                time.sleep(DELAY)
        bot.send_message(chat_id, f"✅  DONE\n👥 {sent}")
        task_queue.task_done()
# ================= HANDLER =================
def handle_private(update: Update, context: CallbackContext):
    if not update.message:
        return
    msg = update.message
    if msg.chat.type != "private":
        return
    if not msg.text:
        msg.reply_text("❌  Kirim link")
        return
    # 🔥 AMBIL SEMUA LINK t.me
    links = re.findall(r"(https?://t\.me/\S+)", msg.text)
    if not links:
        msg.reply_text("❌  Tidak ada link t.me")
        return
    data = load_partner()
    valid = False
    for link in links:
        username = normalize_link(link)
        for p in data:
            if p["username"] == username:
                valid = True
                break
    if not valid:
        msg.reply_text("❌  Link tidak terdaftar partner")
        return
    for chat_id in TARGET_CHATS:
        task_queue.put((chat_id, msg.text))  # 🔥 kirim FULL text
    msg.reply_text("🔥 Tagall jalan")

# ================= MAIN =================
def start_cmd(update: Update, context: CallbackContext):
    update.message.reply_text("✅  Bot aktif")
def main():
    global bot
    updater = Updater(TOKEN, use_context=True)
    bot = updater.bot
    dp = updater.dispatcher
    dp.add_handler(CommandHandler("start", start_cmd))
    dp.add_handler(CommandHandler("addpartner", add_partner))
    dp.add_handler(CommandHandler("delpartner", del_partner))
    dp.add_handler(CommandHandler("listpartner", list_partner))
    dp.add_handler(MessageHandler(Filters.text & ~Filters.command, handle_private))
    client.start()
    print("✅  Telethon nyala")
    t = threading.Thread(target=tagall_worker)
    t.daemon = True
    t.start()
    updater.start_polling()
    updater.idle()
if __name__ == "__main__":
    main()
