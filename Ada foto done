OWNER_ID = 8209644174
PARTNER_FILE = "partner.json"
SETTING_FILE = "setting.json"

# TELETHON
api_id = 33370509
api_hash = "669af6caebf2aca264b16cf8b40d37b2"
client = TelegramClient("session_new", api_id, api_hash)

task_queue = Queue()

